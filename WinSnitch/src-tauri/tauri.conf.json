{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinSnitch",
  "version": "1.0.0",
  "identifier": "io.github.evilsocket.winsnitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WinSnitch",
        "width": 1024,
        "height": 768,
        "decorations": true,
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
